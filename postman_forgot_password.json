{
    "info": {
        "name": "Tashyik - Forgot Password (OTP) Flow",
        "description": "Postman collection for the forgot password flow using OTP.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. Send OTP",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/json",
                        "type": "text"
                    }
                ],
                "body": {
                    "mode": "formdata",
                    "formdata": [
                        {
                            "key": "email",
                            "value": "user@example.com",
                            "type": "text",
                            "description": "The user's registered email address"
                        }
                    ]
                },
                "url": {
                    "raw": "{{base_url}}/api/forgot-password",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "forgot-password"
                    ]
                },
                "description": "Sends a 6-digit OTP to the user's email."
            },
            "response": []
        },
        {
            "name": "2. Verify OTP",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/json",
                        "type": "text"
                    }
                ],
                "body": {
                    "mode": "formdata",
                    "formdata": [
                        {
                            "key": "email",
                            "value": "user@example.com",
                            "type": "text"
                        },
                        {
                            "key": "otp",
                            "value": "123456",
                            "type": "text",
                            "description": "The 6-digit OTP sent to the user's email"
                        }
                    ]
                },
                "url": {
                    "raw": "{{base_url}}/api/verify-otp",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "verify-otp"
                    ]
                },
                "description": "Verifies the 6-digit OTP for the given email address. This is optional but good for UX validation."
            },
            "response": []
        },
        {
            "name": "3. Reset Password",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/json",
                        "type": "text"
                    }
                ],
                "body": {
                    "mode": "formdata",
                    "formdata": [
                        {
                            "key": "email",
                            "value": "user@example.com",
                            "type": "text"
                        },
                        {
                            "key": "otp",
                            "value": "123456",
                            "type": "text"
                        },
                        {
                            "key": "password",
                            "value": "Password123!",
                            "type": "text",
                            "description": "The new password"
                        },
                        {
                            "key": "password_confirmation",
                            "value": "Password123!",
                            "type": "text",
                            "description": "Confirmation of the new password"
                        }
                    ]
                },
                "url": {
                    "raw": "{{base_url}}/api/reset-password",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "reset-password"
                    ]
                },
                "description": "Resets the user's password using the verified OTP."
            },
            "response": []
        }
    ],
    "variable": [
        {
            "key": "base_url",
            "value": "http://api.localhost:8000",
            "type": "string"
        }
    ]
}
