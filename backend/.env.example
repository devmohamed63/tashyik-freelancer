APP_NAME=Tashyik
APP_ENV=local #local, staging, uploading, production
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Riyadh
APP_URL=http://dashboard.local.test

BASE_DOMAIN=local.test
DASHBOARD_SUBDOMAIN=dashboard
API_SUBDOMAIN=api

# Canonical URL (emails, redirects, sitemap base). On server: https://www.tashyik.com
FRONTEND_URL=http://localhost:3000
# CORS: comma-separated *additional* origins (local/preview). FRONTEND_URL is merged automatically.
FRONTEND_URLS=http://local.test:3000,http://127.0.0.1:3000

# Optional. Override invoice link (emails + Daftra). Use {id} for local invoice id.
# If unset, links use public/i/{secret_token} on the dashboard host (no long ?signature= query).
# TASHYIK_INVOICE_SHOW_URL=https://example.com/custom/{id}
# TASHYIK_PUBLIC_INVOICE_LINK_TTL_DAYS=1825
# false = invoice emails do not link to Tashyik’s public invoice HTML page (Daftra preview URL only when API returns it).
# TASHYIK_INVOICE_EMAILS_INCLUDE_LOCAL_PUBLIC_LINK=false

CDN_URL=http://cdn.local.test

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

DB_HOST=127.0.0.1
DB_DATABASE=tashyik
DB_USERNAME=root
DB_PASSWORD=

# Brevo (SMTP relay). Set MAIL_PASSWORD to your SMTP key from Brevo dashboard.
MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="info@tashyik.com"
MAIL_FROM_NAME="${APP_NAME}"

# database|redis|sync — use `sync` on local dev so invoice emails send without `queue:work`; production often uses `database` + worker
QUEUE_CONNECTION=sync

VITE_APP_NAME="${APP_NAME}"

# Maximum distance to the service provider in KM
SERVICE_PROVIDER_MAX_DISTANCE=10

# Service provider visit cost
SERVICE_VISIT_COST=50

# Tax rate percintage on all invoices
INVOICE_TAX_RATE=15

# Customer App
CUSTOMER_APP_VERSION=1.1.6
CUSTOMER_APP_UPDATE_REQUIRED=true
CUSTOMER_APP_URL_GOOGLE_PLAY="https://play.google.com/store/apps/details?id=com.tashyik.app"
CUSTOMER_APP_URL_APP_STORE="https://apps.apple.com/us/app/%D8%AA%D8%B4%D9%8A%D9%8A%D9%83-%D9%84%D9%84%D8%B5%D9%8A%D8%A7%D9%86%D8%A9-%D8%A7%D9%84%D9%85%D9%86%D8%B2%D9%84%D9%8A%D8%A9/id6754100648"

# Service provider App
SERVICE_PROVIDER_APP_VERSION=1.1.6
SERVICE_PROVIDER_APP_UPDATE_REQUIRED=true
SERVICE_PROVIDER_APP_URL_GOOGLE_PLAY="https://play.google.com/store/apps/details?id=com.tashyiktechnical.app"
SERVICE_PROVIDER_APP_URL_APP_STORE="https://apps.apple.com/us/app/%D8%AA%D8%B4%D9%8A%D9%8A%D9%83-%D9%81%D9%86%D9%89/id6754100703"

# Firebase
FIREBASE_CREDENTIALS=storage/app/private/google-service-account.json

# Paymob
PAYMOB_CURRENCY=EGP
PAYMOB_ENDPOINT=https://accept.paymob.com
PAYMOB_PAYMENT_METHODS=5341355,5341354,5341352,5341166,5257426
PAYMOB_API_KEY=
PAYMOB_PUBLIC_KEY=
PAYMOB_SECRET_KEY=
PAYMOB_HMAC=

# Daftra ERP
DAFTRA_SUBDOMAIN=wadhacompany
DAFTRA_COST_CENTER_ID=1
DAFTRA_API_KEY=
# Treasury/bank account that will receive client payments (receipt id from Daftra)
DAFTRA_BANK_ACCOUNT_ID=
# Income account all sold services are routed to (إيراد مبيعات)
# Used for completed orders and additional-services invoices.
DAFTRA_REVENUE_ACCOUNT_ID=
# Return/refund account for credit notes (مردود مبيعات)
DAFTRA_RETURN_ACCOUNT_ID=
# Expense account used for auto-syncing service provider payout bank transfers to Daftra.
DAFTRA_SP_PAYOUT_ACCOUNT_ID=51
# After a sales invoice is synced to Daftra, email the service provider (platform + Daftra view links only; no PDF attachment). BCC accounting.
DAFTRA_INVOICE_PDF_EMAIL_ENABLED=true
DAFTRA_INVOICE_PDF_BCC_EMAIL=info@apptml.com
# GET invoice JSON after sync to save invoice_html_url / invoice_pdf_url for email links (no owner login).
DAFTRA_FETCH_PUBLIC_INVOICE_URL=true
# Download invoice_pdf_url and attach the PDF to the Daftra invoice email (same file as in Daftra).
DAFTRA_ATTACH_INVOICE_PDF_TO_EMAIL=true
# Debug: php artisan daftra:invoice-json 18 --resolve   (prints GET invoices/18.json + resolved customer URL)
# Resend that email (To = SP, BCC = above): php artisan daftra:resend-invoice-pdf {invoice_id} --force
