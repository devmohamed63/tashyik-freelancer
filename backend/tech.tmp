                                    <span class="text-[11px] text-gray-400 truncate" x-text="tech.last_seen_at"></span>
                                </div>
                            </div>
                            <span class="popup-badge text-[10px] flex-shrink-0" :class="tech.status" x-text="statusLabels[tech.status]"></span>
                        </div>
                    </template>

